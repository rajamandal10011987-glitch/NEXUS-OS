<!DOCTYPE html>
<html lang="en"><head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>NEXUS — Personal OS</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg0:#030b18;--bg1:#06111f;--bg2:#0a1a2e;--b1:#1a4a80;--b2:#1e5a99;--b3:#2a7acc;
  --acc:#3d9eff;--acc2:#00c8ff;--glow:0 0 12px rgba(61,158,255,.35);--glow2:0 0 20px rgba(61,158,255,.55);
  --gold:#ffd700;--danger:#ff3355;--success:#00e87a;
  --txt:#c8e0ff;--txt2:#6b9fd4;--txt3:#3d6f99;
  --re:#888;--rd:#4caf50;--rc:#3d9eff;--rb:#c278ff;--ra:#ff9800;--rs:#ffd700;--rss:#ff4455;--rsss:#fff;
}
body{font-family:system-ui,sans-serif;background:var(--bg0);color:var(--txt);min-height:100vh}
.nx{max-width:900px;margin:0 auto;min-height:100vh;display:flex;flex-direction:column;position:relative}
/* HEADER */
.hd{background:var(--bg1);border-bottom:1px solid var(--b1);padding:10px 16px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50}
.logo{font-size:15px;font-weight:800;letter-spacing:.2em;color:var(--acc);text-shadow:var(--glow)}
.logo em{color:var(--acc2);font-style:normal}
.rnk{font-size:9px;font-weight:700;padding:2px 8px;border-radius:2px;border:1px solid;letter-spacing:.12em}
.xp-t{width:90px;height:3px;background:var(--b1);border-radius:2px;overflow:hidden}
.xp-f{height:100%;background:linear-gradient(90deg,var(--acc),var(--acc2));transition:width .6s;box-shadow:0 0 6px var(--acc)}
/* NAV */
.nav{background:var(--bg1);border-bottom:1px solid var(--b1);display:flex;overflow-x:auto;position:sticky;top:49px;z-index:40}
.nav::-webkit-scrollbar{height:0}
.nb{padding:9px 10px;font-size:9px;font-weight:700;background:none;border:none;border-bottom:2px solid transparent;color:var(--txt3);cursor:pointer;white-space:nowrap;font-family:inherit;letter-spacing:.07em;transition:color .15s}
.nb.on{color:var(--acc2);border-bottom-color:var(--acc2)}
.nb:hover:not(.on){color:var(--txt2)}
/* BODY */
.body{padding:14px;flex:1;background:var(--bg0)}
.panel{display:none}.panel.on{display:block}
/* CARDS */
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:7px;margin-bottom:14px}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;margin-bottom:14px}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
@media(max-width:520px){.g4{grid-template-columns:repeat(2,1fr)}.g3{grid-template-columns:repeat(2,1fr)}.g2{grid-template-columns:1fr}}
.card{background:var(--bg2);border:1px solid var(--b1);border-radius:4px;padding:10px 12px;position:relative;overflow:hidden}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--b3),transparent)}
.cl{font-size:9px;color:var(--txt3);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px;font-weight:600}
.cv{font-size:18px;font-weight:700}
/* SH */
.sh{font-size:9px;font-weight:700;color:var(--acc2);text-transform:uppercase;letter-spacing:.12em;margin:14px 0 7px;display:flex;align-items:center;gap:7px}
.sh::before{content:'▶';font-size:7px;color:var(--acc)}
.sh::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,var(--b2),transparent)}
/* QUEST */
.qi{background:var(--bg2);border:1px solid var(--b1);border-radius:4px;padding:8px 11px;display:flex;align-items:center;gap:8px;margin-bottom:5px;transition:opacity .2s}
.qi.done{opacity:.35}
.qchk{width:16px;height:16px;border:1.5px solid var(--acc);border-radius:2px;display:flex;align-items:center;justify-content:center;flex-shrink:0;cursor:pointer;color:var(--bg0);background:transparent;transition:background .15s;font-size:9px}
.qchk.done{background:var(--acc);box-shadow:0 0 5px var(--acc)}
/* STAT BAR */
.sbr{display:flex;align-items:center;gap:8px;margin-bottom:6px}
.sbn{width:75px;font-size:10px;font-weight:700;color:var(--txt2);text-transform:uppercase;flex-shrink:0}
.sbt{flex:1;height:3px;background:var(--b1);border-radius:2px}
.sbf{height:100%;border-radius:2px;transition:width .5s}
.sbv{width:26px;text-align:right;font-size:11px;font-weight:700;flex-shrink:0}
.sbs{font-size:9px;color:var(--txt3);margin-bottom:8px;padding-left:83px}
/* HABIT */
.hi{background:var(--bg2);border:1px solid var(--b1);border-radius:4px;padding:8px 11px;display:flex;align-items:center;justify-content:space-between;margin-bottom:5px;transition:border-color .2s}
.hi.tdone{border-color:var(--success);opacity:.65}
.hbtn{padding:3px 8px;border-radius:3px;font-size:10px;border:1px solid;cursor:pointer;background:transparent;font-family:inherit;font-weight:600}
/* FINANCE */
.fr{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid var(--b1);font-size:11px}
/* CONNECTOR */
.ci-w{margin-bottom:5px}
.ci{background:var(--bg2);border:1px solid var(--b1);border-radius:4px;padding:9px 12px;display:flex;align-items:center;justify-content:space-between}
.ci-s{background:rgba(61,158,255,.04);border:1px solid var(--b1);border-top:none;border-radius:0 0 4px 4px;padding:7px 12px;display:flex;align-items:center;justify-content:space-between}
.tog{width:34px;height:18px;border-radius:9px;background:var(--b1);border:1px solid var(--b2);cursor:pointer;position:relative;transition:background .2s;flex-shrink:0}
.tog.on{background:var(--acc);border-color:var(--acc);box-shadow:0 0 8px var(--acc)}
.tog::after{content:'';position:absolute;width:12px;height:12px;border-radius:50%;background:#fff;top:2px;left:2px;transition:left .2s}
.tog.on::after{left:19px}
.tog.sm{width:26px;height:14px}.tog.sm::after{width:9px;height:9px;top:2px;left:2px}.tog.sm.on::after{left:14px}
/* INPUTS */
.in{background:var(--bg2);border:1px solid var(--b2);border-radius:4px;padding:7px 10px;font-size:12px;color:var(--txt);font-family:inherit;width:100%}
.in:focus{outline:none;border-color:var(--acc)}
.in::placeholder{color:var(--txt3)}
select.in option{background:var(--bg2);color:var(--txt)}
.btn{padding:7px 12px;border-radius:4px;font-size:11px;border:1px solid var(--acc);color:var(--acc);background:transparent;cursor:pointer;font-family:inherit;font-weight:600;transition:all .15s;white-space:nowrap}
.btn:hover{background:rgba(61,158,255,.1)}.btn.p{background:var(--acc);color:var(--bg0)}.btn.p:hover{opacity:.85}.btn.sm{font-size:10px;padding:4px 9px}
.xb{background:none;border:none;color:var(--txt3);cursor:pointer;padding:2px;line-height:1;flex-shrink:0;font-size:13px}.xb:hover{color:var(--danger)}
.ar{display:flex;gap:6px;margin-bottom:11px;align-items:center}
/* TABS */
.stabs{display:flex;gap:4px;margin-bottom:11px;flex-wrap:wrap}
.stab{padding:4px 10px;font-size:10px;border-radius:2px;border:1px solid var(--b2);background:transparent;color:var(--txt3);cursor:pointer;font-family:inherit;font-weight:600;transition:all .15s}
.stab.on{background:var(--acc);border-color:var(--acc);color:var(--bg0)}
/* RING */
.rw{display:flex;flex-direction:column;align-items:center;gap:4px}
/* NOTIFY */
.notif{position:fixed;top:12px;right:12px;background:var(--bg2);border:1px solid var(--acc2);border-radius:4px;padding:9px 13px;font-size:11px;color:var(--acc2);z-index:999;display:none;max-width:260px;box-shadow:var(--glow)}
/* LVL UP */
.lvo{display:none;position:fixed;inset:0;background:rgba(3,11,24,.88);z-index:998;align-items:center;justify-content:center}
.lvbox{background:var(--bg1);border:2px solid var(--acc);border-radius:4px;padding:28px 40px;text-align:center;cursor:pointer;box-shadow:var(--glow2)}
/* HEAT */
.hb{width:12px;height:12px;border-radius:2px;flex-shrink:0}
/* RANK ROW */
.rrw{display:flex;align-items:center;gap:10px;padding:7px 11px;background:var(--bg2);border:1px solid var(--b1);border-radius:4px;margin-bottom:4px}
.rc2{width:26px;height:26px;border-radius:50%;border:1.5px solid;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;flex-shrink:0}
/* CAL */
.cal-hdr{display:grid;grid-template-columns:repeat(7,1fr);gap:3px;margin-bottom:4px}
.cal-hdr div{text-align:center;font-size:9px;color:var(--txt3);font-weight:700;text-transform:uppercase}
.cal-g{display:grid;grid-template-columns:repeat(7,1fr);gap:3px;margin-bottom:12px}
.cd{aspect-ratio:1;background:var(--bg2);border:1px solid var(--b1);border-radius:3px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:10px;cursor:pointer;color:var(--txt2);transition:all .15s}
.cd.today{border-color:var(--acc2);color:var(--acc2)}.cd.has{background:rgba(61,158,255,.1)}.cd:hover{border-color:var(--b3)}.cd.sel{border-color:var(--acc);background:rgba(61,158,255,.15)}
/* CAREER */
.ml{background:var(--bg2);border:1px solid var(--b1);border-radius:4px;padding:9px 12px;margin-bottom:5px;display:flex;align-items:flex-start;gap:9px}
.ml-d{width:8px;height:8px;border-radius:50%;background:var(--acc);flex-shrink:0;margin-top:4px;box-shadow:0 0 5px var(--acc)}
/* PF */
.pff{background:var(--bg2);border:1px solid var(--b1);border-radius:4px;padding:8px 11px;margin-bottom:6px}
.pfl{font-size:9px;color:var(--acc2);text-transform:uppercase;letter-spacing:.1em;margin-bottom:4px;font-weight:700}
/* CHARTS */
.cw{background:var(--bg2);border:1px solid var(--b1);border-radius:4px;padding:10px;margin-bottom:10px}
.cleg{display:flex;gap:8px;flex-wrap:wrap;margin-top:7px}
.cli{display:flex;align-items:center;gap:5px;font-size:10px;color:var(--txt2)}
.cld{width:8px;height:8px;border-radius:50%;flex-shrink:0}
/* PLROW */
.plrow{background:var(--bg2);border:1px solid var(--b1);border-radius:4px;padding:9px 12px;margin-bottom:5px;display:flex;align-items:center;gap:10px;flex-wrap:wrap}
/* QL */
.ql-g{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:12px;min-height:40px}
.ql-c{display:flex;flex-direction:column;align-items:center;justify-content:center;width:76px;padding:10px 6px;background:var(--bg2);border:1px solid var(--b2);border-radius:6px;text-decoration:none;color:var(--txt);cursor:pointer;transition:all .15s;position:relative}
.ql-c:hover{border-color:var(--acc);background:rgba(61,158,255,.08);box-shadow:var(--glow)}
.ql-i{font-size:20px;margin-bottom:5px;line-height:1}
.ql-n{font-size:9px;text-align:center;color:var(--txt2);font-weight:600;word-break:break-word;line-height:1.3}
.ql-x{position:absolute;top:2px;right:3px;background:none;border:none;color:var(--txt3);cursor:pointer;font-size:10px;padding:1px;line-height:1}
.ql-x:hover{color:var(--danger)}
/* CMD */
.cmd-r{background:var(--bg2);border:1px solid var(--b1);border-radius:4px;padding:8px 11px;margin-bottom:5px;font-size:11px}
.cmd-in{font-size:11px;color:var(--txt2)}
.cmd-out{margin-top:4px;white-space:pre-wrap;font-size:11px}
/* LINKEDIN OUT */
.li-out{background:var(--bg1);border:1px solid var(--b2);border-radius:4px;padding:13px;font-size:12px;line-height:1.7;color:var(--txt);white-space:pre-wrap;max-height:380px;overflow-y:auto}
/* STATUS BAR */
.sb-bar{background:rgba(61,158,255,.06);border:1px solid var(--b1);border-radius:4px;padding:6px 11px;font-size:10px;color:var(--txt3);margin-bottom:10px;display:flex;align-items:center;gap:7px}
.sb-dot{width:6px;height:6px;border-radius:50%;background:var(--success);box-shadow:0 0 5px var(--success);flex-shrink:0}
</style>
</head>
<body>
<div class="nx">
<div class="hd">
  <div style="display:flex;align-items:center;gap:9px">
    <div class="logo">NEX<em>US</em></div>
    <div class="rnk" id="rnkBadge" style="color:var(--re);border-color:var(--re)">RANK E</div>
    <div style="font-size:10px;color:var(--txt3)" id="hdTitle">Awakened Hunter</div>
  </div>
  <div style="display:flex;align-items:center;gap:11px">
    <div style="font-size:10px;color:var(--txt3)">LVL <strong style="color:var(--acc)" id="hdLvl">1</strong></div>
    <div>
      <div style="font-size:9px;color:var(--txt3);margin-bottom:2px">XP <span style="color:var(--acc2)" id="hdXPtxt">0/100</span></div>
      <div class="xp-t"><div class="xp-f" id="hdXPbar" style="width:0%"></div></div>
    </div>
    <div style="font-size:11px">🔥 <strong id="hdStreak">1</strong></div>
  </div>
</div>
<div class="nav">
  <button class="nb on" onclick="go('dash',this)">⬡ SYSTEM</button>
  <button class="nb" onclick="go('player',this)">◈ PLAYER</button>
  <button class="nb" onclick="go('quests',this)">⚔ QUESTS</button>
  <button class="nb" onclick="go('habits',this)">↺ HABITS</button>
  <button class="nb" onclick="go('stats',this)">◎ STATS</button>
  <button class="nb" onclick="go('career',this)">◆ CAREER</button>
  <button class="nb" onclick="go('wealth',this)">◈ WEALTH</button>
  <button class="nb" onclick="go('fame',this)">★ FAME</button>
  <button class="nb" onclick="go('cal',this)">▦ CAL</button>
  <button class="nb" onclick="go('voice',this)">◉ VOICE</button>
  <button class="nb" onclick="go('conn',this)">⬡ CONN</button>
  <button class="nb" onclick="go('cmd',this)">⌘ CMD</button>
</div>
<div class="body">

<!-- DASH -->
<div class="panel on" id="p-dash">
  <div class="g4">
    <div class="card"><div class="cl">Level</div><div class="cv" id="dLvl" style="color:var(--acc)">1</div></div>
    <div class="card"><div class="cl">Total XP</div><div class="cv" id="dXP">0</div></div>
    <div class="card"><div class="cl">Streak</div><div class="cv" id="dStreak" style="color:#ff7700">1</div></div>
    <div class="card"><div class="cl">Rank</div><div class="cv" id="dRank" style="color:var(--re)">E</div></div>
  </div>
  <div class="sh">Progress Rings</div>
  <div style="display:flex;gap:10px;margin-bottom:14px;overflow-x:auto;padding-bottom:4px">
    <div class="rw card" style="min-width:82px;padding:10px 7px">
      <svg width="54" height="54" viewBox="0 0 64 64"><circle cx="32" cy="32" r="26" fill="none" stroke="var(--b1)" stroke-width="4"/><circle id="rXP" cx="32" cy="32" r="26" fill="none" stroke="var(--acc)" stroke-width="4" stroke-linecap="round" stroke-dasharray="163" stroke-dashoffset="163" style="transform:rotate(-90deg);transform-origin:center;transition:stroke-dashoffset .6s"/><text x="32" y="36" text-anchor="middle" fill="var(--txt)" font-size="11" font-weight="700" id="rXPt">0%</text></svg>
      <div style="font-size:9px;color:var(--txt3)">XP</div>
    </div>
    <div class="rw card" style="min-width:82px;padding:10px 7px">
      <svg width="54" height="54" viewBox="0 0 64 64"><circle cx="32" cy="32" r="26" fill="none" stroke="var(--b1)" stroke-width="4"/><circle id="rQ" cx="32" cy="32" r="26" fill="none" stroke="var(--success)" stroke-width="4" stroke-linecap="round" stroke-dasharray="163" stroke-dashoffset="163" style="transform:rotate(-90deg);transform-origin:center;transition:stroke-dashoffset .6s"/><text x="32" y="36" text-anchor="middle" fill="var(--txt)" font-size="11" font-weight="700" id="rQt">0%</text></svg>
      <div style="font-size:9px;color:var(--txt3)">Quests</div>
    </div>
    <div class="rw card" style="min-width:82px;padding:10px 7px">
      <svg width="54" height="54" viewBox="0 0 64 64"><circle cx="32" cy="32" r="26" fill="none" stroke="var(--b1)" stroke-width="4"/><circle id="rH" cx="32" cy="32" r="26" fill="none" stroke="#ff7700" stroke-width="4" stroke-linecap="round" stroke-dasharray="163" stroke-dashoffset="163" style="transform:rotate(-90deg);transform-origin:center;transition:stroke-dashoffset .6s"/><text x="32" y="36" text-anchor="middle" fill="var(--txt)" font-size="11" font-weight="700" id="rHt">0</text></svg>
      <div style="font-size:9px;color:var(--txt3)">Habits</div>
    </div>
    <div class="rw card" style="min-width:82px;padding:10px 7px">
      <svg width="54" height="54" viewBox="0 0 64 64"><circle cx="32" cy="32" r="26" fill="none" stroke="var(--b1)" stroke-width="4"/><circle id="rS" cx="32" cy="32" r="26" fill="none" stroke="var(--gold)" stroke-width="4" stroke-linecap="round" stroke-dasharray="163" stroke-dashoffset="163" style="transform:rotate(-90deg);transform-origin:center;transition:stroke-dashoffset .6s"/><text x="32" y="36" text-anchor="middle" fill="var(--txt)" font-size="11" font-weight="700" id="rSt">1</text></svg>
      <div style="font-size:9px;color:var(--txt3)">Streak</div>
    </div>
  </div>
  <div class="sh">35-Day Activity</div>
  <div id="dHeat" style="display:flex;gap:3px;flex-wrap:wrap;margin-bottom:14px"></div>
  <div class="g2">
    <div><div class="sh">Player Stats</div><div class="card" id="dStats"></div></div>
    <div><div class="sh">Today's Quests</div><div id="dQuests"></div><button class="btn" style="width:100%;margin-top:6px;font-size:10px" onclick="goTo('quests')">View all →</button></div>
  </div>
  <div class="sh" style="margin-top:14px">Activity Log</div>
  <div id="dLog"></div>
</div>

<!-- PLAYER -->
<div class="panel" id="p-player">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
    <div style="display:flex;align-items:center;gap:12px">
      <div style="width:52px;height:52px;border-radius:50%;border:2px solid var(--acc);display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:800;color:var(--acc);background:var(--bg2);box-shadow:var(--glow);flex-shrink:0">R</div>
      <div>
        <div style="font-size:15px;font-weight:700">Rupayan Mandal</div>
        <div style="font-size:10px;color:var(--acc2)" id="pfRole">Awakened Hunter · Rank E · Lv.1</div>
      </div>
    </div>
    <button class="btn sm" id="pfEditBtn" onclick="toggleEdit()">Edit Profile</button>
  </div>
  <div id="pfFields"></div>
</div>

<!-- QUESTS -->
<div class="panel" id="p-quests">
  <div class="stabs" id="qStabs">
    <button class="stab on" onclick="qTab('daily',this)">Daily</button>
    <button class="stab" onclick="qTab('main',this)">Main Story</button>
    <button class="stab" onclick="qTab('bonus',this)">Bonus</button>
  </div>
  <div id="qt-daily">
    <div class="ar"><input class="in" id="qInD" placeholder="New daily quest..." onkeydown="if(event.key==='Enter')addQ('daily')"><select class="in" id="qXpD" style="width:78px"><option value="10">10 XP</option><option value="20">20 XP</option><option value="30" selected>30 XP</option><option value="50">50 XP</option></select><button class="btn p" onclick="addQ('daily')">+</button></div>
    <div id="ql-daily"></div>
  </div>
  <div id="qt-main" style="display:none">
    <div class="ar"><input class="in" id="qInM" placeholder="New main quest..." onkeydown="if(event.key==='Enter')addQ('main')"><select class="in" id="qXpM" style="width:78px"><option value="50">50 XP</option><option value="100" selected>100 XP</option><option value="200">200 XP</option><option value="500">500 XP</option></select><button class="btn p" onclick="addQ('main')">+</button></div>
    <div id="ql-main"></div>
  </div>
  <div id="qt-bonus" style="display:none">
    <div class="ar"><input class="in" id="qInB" placeholder="New bonus quest..." onkeydown="if(event.key==='Enter')addQ('bonus')"><select class="in" id="qXpB" style="width:78px"><option value="15">15 XP</option><option value="25" selected>25 XP</option><option value="40">40 XP</option></select><button class="btn p" onclick="addQ('bonus')">+</button></div>
    <div id="ql-bonus"></div>
  </div>
</div>

<!-- HABITS -->
<div class="panel" id="p-habits">
  <div style="background:rgba(0,232,122,.06);border:1px solid rgba(0,232,122,.2);border-radius:4px;padding:8px 11px;font-size:10px;color:var(--txt2);margin-bottom:11px">✓ Each habit can only be tracked <strong>once per day</strong>. Green = already logged today.</div>
  <div class="sh">Positive Habits <span style="color:var(--success);font-weight:400;letter-spacing:normal;font-size:10px">+15 XP</span></div>
  <div class="ar"><input class="in" id="hInG" placeholder="Add good habit..." onkeydown="if(event.key==='Enter')addH('good')"><button class="btn p" onclick="addH('good')">+</button></div>
  <div id="hl-good"></div>
  <div class="sh" style="margin-top:16px">Negative Habits <span style="color:var(--danger);font-weight:400;letter-spacing:normal;font-size:10px">-20 XP</span></div>
  <div class="ar"><input class="in" id="hInB" placeholder="Add bad habit to break..." onkeydown="if(event.key==='En
