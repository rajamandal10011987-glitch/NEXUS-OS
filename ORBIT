<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1">
<title>ORBIT — Daily Intelligence</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,400;1,700&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#030b18;--bg1:#06111f;--bg2:#0a1a2e;--bg3:#0f2240;
  --b1:#1a4a80;--b2:#1e5a99;--b3:#2a7acc;
  --bdr:rgba(26,74,128,.55);--bdr2:rgba(42,122,204,.4);
  --acc:#3d9eff;--acc2:#00c8ff;--acc3:#7dd3fc;
  --grad:linear-gradient(135deg,#1a4a80 0%,#0ea5e9 100%);
  --glow:0 0 14px rgba(61,158,255,.3);--glow2:0 0 28px rgba(61,158,255,.5);
  --txt:#c8e0ff;--txt2:#6b9fd4;--txt3:#3d6f99;
  --gold:#ffd700;--green:#00e87a;--red:#ff3355;
  --c-ai:#3d9eff;--c-biz:#ffd700;--c-tech:#00c8ff;--c-mkt:#00e87a;--c-wlth:#c278ff;
  --c-science:#60a5fa;--c-health:#34d399;--c-climate:#4ade80;
  --c-crypto:#f59e0b;--c-fashion:#f472b6;--c-sports:#fb923c;--c-geo:#818cf8;
  --serif:'Playfair Display',Georgia,serif;--sans:'DM Sans',system-ui,sans-serif;
}
html,body{height:100%;overflow-x:hidden}
body{font-family:var(--sans);background:var(--bg);color:var(--txt);-webkit-font-smoothing:antialiased}
body::before{content:'';position:fixed;inset:0;z-index:0;pointer-events:none;
  background:radial-gradient(ellipse 70% 50% at 15% 5%,rgba(61,158,255,.07) 0%,transparent 55%),
             radial-gradient(ellipse 50% 40% at 85% 85%,rgba(0,200,255,.05) 0%,transparent 50%)}
::-webkit-scrollbar{width:3px}::-webkit-scrollbar-thumb{background:rgba(61,158,255,.25);border-radius:3px}

.screen{position:fixed;inset:0;z-index:10;overflow-y:auto;display:none}
.screen.on{display:block}

/* ─── AUTH ─── */
#sAuth{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100%;padding:24px 20px;background:var(--bg)}
.brand-logo{font-family:var(--serif);font-size:50px;font-weight:900;letter-spacing:.05em;background:linear-gradient(135deg,var(--acc),var(--acc2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;text-align:center}
.brand-tag{font-size:9px;letter-spacing:.28em;text-transform:uppercase;color:var(--txt3);margin-top:6px;text-align:center;margin-bottom:36px}
.auth-card{background:var(--bg2);border:1px solid var(--bdr2);border-radius:22px;padding:28px 24px;width:100%;max-width:360px;box-shadow:var(--glow)}
.auth-tabs{display:flex;background:var(--bg3);border-radius:14px;padding:4px;gap:4px;margin-bottom:22px}
.auth-tab{flex:1;padding:9px;font-size:11px;font-weight:600;font-family:var(--sans);background:none;border:none;color:var(--txt3);cursor:pointer;border-radius:10px;transition:all .2s;letter-spacing:.03em}
.auth-tab.on{background:var(--bg2);color:var(--txt);box-shadow:0 2px 14px rgba(0,0,0,.35)}
.fi{width:100%;background:var(--bg3);border:1px solid var(--bdr);border-radius:13px;padding:12px 15px;font-size:13px;font-family:var(--sans);color:var(--txt);margin-bottom:10px;transition:border-color .2s;outline:none}
.fi:focus{border-color:var(--acc)}
.fi::placeholder{color:var(--txt3)}
.fi option{background:var(--bg2)}
.auth-btn{width:100%;padding:14px;border-radius:14px;font-size:12px;font-weight:700;font-family:var(--sans);letter-spacing:.07em;border:none;cursor:pointer;margin-top:4px;background:var(--grad);color:#fff;box-shadow:var(--glow);transition:opacity .2s,transform .15s}
.auth-btn:hover{opacity:.88;transform:translateY(-1px)}
.auth-err{font-size:11px;color:var(--red);text-align:center;margin-bottom:10px;padding:9px 13px;background:rgba(255,51,85,.07);border:1px solid rgba(255,51,85,.18);border-radius:11px;display:none;line-height:1.55}
.auth-hint{margin-top:20px;font-size:10px;color:var(--txt3);text-align:center;line-height:1.9;max-width:300px}

/* ─── APP ─── */
#sApp{background:var(--bg)}
.app-inner{max-width:640px;margin:0 auto;padding-bottom:90px;min-height:100vh}

/* ─── TOPBAR ─── */
.topbar{position:sticky;top:0;z-index:50;background:rgba(3,11,24,.93);backdrop-filter:blur(22px);-webkit-backdrop-filter:blur(22px);border-bottom:1px solid var(--bdr);padding:10px 16px;display:flex;align-items:center;justify-content:space-between}
.topbar-logo{font-family:var(--serif);font-size:20px;font-weight:900;background:linear-gradient(135deg,var(--acc),var(--acc2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:.05em}
.topbar-acts{display:flex;align-items:center;gap:6px}
.tb{padding:6px 12px;border-radius:20px;font-size:9px;font-weight:700;font-family:var(--sans);background:var(--bg2);border:1px solid var(--bdr);color:var(--txt3);cursor:pointer;transition:all .18s;letter-spacing:.07em;text-transform:uppercase;white-space:nowrap}
.tb:hover{border-color:var(--acc);color:var(--acc)}
.av{width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--b1),var(--acc));display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;cursor:pointer;flex-shrink:0;font-family:var(--sans);box-shadow:var(--glow)}

/* ─── HERO ─── */
.hero{padding:26px 16px 16px}
.hero-date{font-size:9px;font-weight:700;color:var(--acc2);letter-spacing:.24em;text-transform:uppercase;margin-bottom:14px}
.hero-hl{font-family:var(--serif);font-size:38px;font-weight:900;line-height:1.1;margin-bottom:22px;letter-spacing:-.015em;color:var(--txt)}
.hero-hl em{font-style:italic;background:linear-gradient(135deg,var(--acc),var(--acc2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}

/* ─── LISTEN BAR ─── */
.listen-bar{display:inline-flex;align-items:center;gap:0;background:var(--bg2);border:1px solid var(--bdr2);border-radius:40px;padding:6px 6px 6px 14px;margin-bottom:6px;max-width:100%}
.lb-ctrl{width:32px;height:32px;border-radius:50%;background:none;border:none;color:var(--txt3);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:13px;transition:all .18s}
.lb-ctrl:hover{color:var(--acc2);background:rgba(61,158,255,.08)}
.lb-play{height:32px;padding:0 14px;border-radius:18px;background:var(--bg3);border:1px solid var(--bdr2);color:var(--txt);font-size:11px;font-weight:700;font-family:var(--sans);cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;transition:all .18s;letter-spacing:.04em;white-space:nowrap}
.lb-play:hover{border-color:var(--acc);color:var(--acc2);box-shadow:var(--glow)}
.lb-label{font-size:10px;color:var(--txt3);padding-left:11px;max-width:150px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

/* ─── GEN CARD ─── */
.gen-card{background:var(--bg2);border:1px solid var(--bdr2);border-radius:22px;padding:20px 18px;margin:0 16px 20px;position:relative;overflow:hidden}
.gen-card::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 85% 40%,rgba(61,158,255,.06),transparent 65%);pointer-events:none}
.gen-card p{font-size:13px;color:var(--txt2);line-height:1.75;margin-bottom:16px}
.gen-btn{display:inline-flex;align-items:center;gap:9px;padding:12px 22px;border-radius:14px;font-size:13px;font-weight:700;font-family:var(--sans);background:var(--grad);color:#fff;border:none;cursor:pointer;box-shadow:var(--glow);transition:all .22s;letter-spacing:.03em}
.gen-btn:hover{transform:translateY(-2px);box-shadow:var(--glow2)}
.gen-btn:active{transform:translateY(0)}
.gen-btn:disabled{opacity:.4;cursor:not-allowed;transform:none}
@keyframes spin{to{transform:rotate(360deg)}}
.spin{display:inline-block;animation:spin .7s linear infinite}
.gen-err{font-size:11px;color:var(--red);margin-top:12px;padding:9px 12px;background:rgba(255,51,85,.07);border:1px solid rgba(255,51,85,.18);border-radius:10px;display:none;line-height:1.6}

/* ─── TABS ─── */
.tabs{display:flex;background:var(--bg2);border:1px solid var(--bdr);border-radius:16px;padding:4px;margin:0 16px 16px;gap:4px}
.tab{flex:1;padding:10px 8px;font-size:11px;font-weight:700;font-family:var(--sans);background:none;border:none;color:var(--txt3);cursor:pointer;border-radius:12px;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:6px;letter-spacing:.05em;text-transform:uppercase}
.tab.on{background:var(--bg3);color:var(--acc2);box-shadow:0 2px 14px rgba(0,0,0,.3);border:1px solid var(--bdr)}

/* ─── TOPICS ─── */
.topics{display:flex;gap:6px;padding:0 16px 16px;overflow-x:auto;-webkit-overflow-scrolling:touch}
.topics::-webkit-scrollbar{display:none}
.tp{padding:6px 14px;border-radius:20px;font-size:9px;font-weight:700;font-family:var(--sans);background:var(--bg2);border:1px solid var(--bdr);color:var(--txt3);cursor:pointer;white-space:nowrap;transition:all .2s;letter-spacing:.07em;text-transform:uppercase;flex-shrink:0}
.tp.on{color:var(--bg);border-color:transparent}

/* ─── WORD SEARCH ─── */
.wsbar{position:relative;margin:0 16px 12px}
.wsbar input{width:100%;background:var(--bg2);border:1px solid var(--bdr);border-radius:14px;padding:10px 44px 10px 40px;font-size:12px;font-family:var(--sans);color:var(--txt);outline:none;transition:border-color .2s}
.wsbar input:focus{border-color:var(--acc)}
.wsbar input::placeholder{color:var(--txt3)}
.ws-ico{position:absolute;left:13px;top:50%;transform:translateY(-50%);font-size:13px;color:var(--txt3);pointer-events:none}
.ws-btn{position:absolute;right:8px;top:50%;transform:translateY(-50%);padding:4px 10px;border-radius:9px;font-size:8px;font-weight:800;font-family:var(--sans);letter-spacing:.1em;background:var(--bg3);border:1px solid var(--bdr2);color:var(--txt3);cursor:pointer;transition:all .15s;text-transform:uppercase}
.ws-btn:hover{border-color:var(--acc);color:var(--acc)}

/* ─── STATUS ─── */
.status{display:flex;align-items:center;gap:8px;padding:0 16px 12px;font-size:9px;color:var(--txt3)}
.sdot{width:5px;height:5px;border-radius:50%;flex-shrink:0;transition:background .3s}
.sdot.live{background:var(--green);box-shadow:0 0 7px var(--green)}
.sdot.idle{background:var(--txt3)}
.sdot.loading{background:var(--acc2);animation:blink .9s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.15}}

/* ─── EXPORT BAR ─── */
.export-bar{display:flex;gap:7px;padding:0 16px 14px;flex-wrap:wrap}
.exp-btn{display:flex;align-items:center;gap:6px;padding:6px 12px;border-radius:10px;font-size:9px;font-weight:700;font-family:var(--sans);background:var(--bg2);border:1px solid var(--bdr);color:var(--txt3);cursor:pointer;transition:all .18s;letter-spacing:.07em;text-transform:uppercase;white-space:nowrap}
.exp-btn:hover{border-color:var(--acc);color:var(--acc)}

/* ─── FEED ─── */
.feed{padding:0 16px}
.cat-section{margin-bottom:26px}
.cat-head{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:11px;padding-bottom:11px;border-bottom:1px solid var(--bdr)}
.cat-left{display:flex;align-items:center;gap:12px}
.cat-emoji{font-size:32px;line-height:1;flex-shrink:0}
.cat-name{font-family:var(--serif);font-size:28px;font-weight:700;line-height:1.1;color:var(--txt)}
.cat-badge{font-size:8px;font-weight:700;color:var(--txt3);letter-spacing:.18em;text-transform:uppercase;display:flex;align-items:center;gap:4px;margin-top:16px;flex-shrink:0}

/* ─── ARTICLE ─── */
.art{padding:13px 0;border-bottom:1px solid rgba(26,74,128,.35)}
.art:last-child{border-bottom:none}
.art-meta{display:flex;align-items:center;gap:7px;margin-bottom:7px}
.art-src{font-size:9px;font-weight:700;color:var(--txt3);text-transform:uppercase;letter-spacing:.1em}
.art-dot{width:2px;height:2px;border-radius:50%;background:var(--txt3);flex-shrink:0}
.art-time{font-size:9px;color:var(--txt3)}
.art-star{margin-left:auto;background:none;border:none;cursor:pointer;font-size:16px;color:var(--txt3);transition:color .18s;padding:2px;line-height:1;flex-shrink:0}
.art-star.on,.art-star:hover{color:var(--gold)}
.art-title{font-family:var(--serif);font-size:19px;font-weight:700;line-height:1.3;color:var(--txt);margin-bottom:7px;cursor:pointer;transition:color .18s;letter-spacing:-.01em}
.art-title:hover{color:var(--acc2)}
.art-sum{font-size:12px;color:var(--txt2);line-height:1.78;margin-bottom:10px;user-select:text;cursor:text}
.art-foot{display:flex;align-items:center;gap:14px}
.art-listen{font-size:9px;font-weight:700;color:var(--txt3);background:none;border:none;cursor:pointer;font-family:var(--sans);letter-spacing:.1em;text-transform:uppercase;display:flex;align-items:center;gap:5px;padding:0;transition:color .18s}
.art-listen:hover{color:var(--acc2)}
.art-read{font-size:9px;font-weight:700;color:var(--acc);text-decoration:none;letter-spacing:.1em;text-transform:uppercase;transition:color .18s}
.art-read:hover{color:var(--acc2)}

/* ─── SKELETON ─── */
.skel-wrap{padding:0 16px}
.skel{padding:14px 0;border-bottom:1px solid rgba(26,74,128,.3)}
.sk{border-radius:6px;background:linear-gradient(90deg,var(--bg2) 25%,rgba(61,158,255,.06) 50%,var(--bg2) 75%);background-size:200% 100%;animation:sh 1.6s infinite linear;margin-bottom:9px}
@keyframes sh{0%{background-position:200% 0}100%{background-position:-200% 0}}

/* ─── EMPTY ─── */
.empty{text-align:center;padding:60px 20px}
.empty-ico{font-size:48px;margin-bottom:14px;opacity:.28;line-height:1}
.empty-t{font-family:var(--serif);font-size:19px;color:var(--txt2);margin-bottom:8px}
.empty-s{font-size:12px;color:var(--txt3);line-height:1.85}

/* ─── PLAYER ─── */
.player{position:fixed;bottom:0;left:0;right:0;z-index:60;background:rgba(6,17,31,.97);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-top:1px solid var(--bdr2);padding:12px 16px 15px;transform:translateY(110%);transition:transform .32s cubic-bezier(.4,0,.2,1)}
.player.up{transform:translateY(0)}
.player-inner{max-width:640px;margin:0 auto;display:flex;align-items:center;gap:10px}
.pl-info{flex:1;min-width:0}
.pl-title{font-size:11px;font-weight:600;color:var(--txt);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:2px}
.pl-sub{font-size:9px;color:var(--txt3);letter-spacing:.04em}
.pl-btns{display:flex;align-items:center;gap:5px;flex-shrink:0}
.pl-b{width:30px;height:30px;border-radius:50%;background:var(--bg3);border:1px solid var(--bdr);color:var(--txt3);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:12px;transition:all .18s}
.pl-b:hover{border-color:var(--acc);color:var(--acc)}
.pl-play{width:36px;height:36px;background:var(--grad);border:none;border-radius:50%;color:#fff;font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:var(--glow);transition:transform .18s}
.pl-play:hover{transform:scale(1.1)}
.pl-rate{background:var(--bg3);border:1px solid var(--bdr);color:var(--txt3);font-size:9px;font-family:var(--sans);padding:3px 7px;border-radius:8px;cursor:pointer;outline:none}
.pl-x{background:none;border:none;color:var(--txt3);cursor:pointer;font-size:15px;padding:4px;transition:color .15s;line-height:1}
.pl-x:hover{color:var(--red)}

/* ─── WORD POPUP ─── */
.wpop{position:fixed;z-index:200;background:var(--bg1);border:1px solid var(--acc);border-radius:16px;padding:14px 16px;max-width:280px;min-width:200px;box-shadow:var(--glow2);display:none}
.wpop-word{font-family:var(--serif);font-size:18px;font-weight:700;color:var(--acc2);margin-bottom:2px}
.wpop-pos{font-size:8px;color:var(--txt3);text-transform:uppercase;letter-spacing:.14em;margin-bottom:8px;font-style:italic}
.wpop-def{font-size:12px;color:var(--txt);line-height:1.68}
.wpop-eg{font-size:11px;color:var(--txt3);margin-top:6px;font-style:italic;line-height:1.5}
.wpop-src{font-size:8px;color:var(--txt3);margin-top:8px;text-align:right;letter-spacing:.07em}
.wpop-x{position:absolute;top:9px;right:12px;background:none;border:none;color:var(--txt3);cursor:pointer;font-size:14px;line-height:1;transition:color .15s}
.wpop-x:hover{color:var(--red)}

/* ─── OVERLAY / MODAL ─── */
.overlay{position:fixed;inset:0;background:rgba(3,11,24,.92);z-index:100;display:none;align-items:flex-start;justify-content:center;padding:16px;overflow-y:auto;backdrop-filter:blur(10px)}
.overlay.open{display:flex}
.mbox{background:var(--bg1);border:1px solid var(--bdr2);border-radius:22px;width:100%;max-width:520px;padding:22px 20px;box-shadow:var(--glow2);margin:auto}
.mhd{font-size:11px;font-weight:800;color:var(--txt2);margin-bottom:16px;display:flex;align-items:center;justify-content:space-between;text-transform:uppercase;letter-spacing:.15em}
.mx{background:none;border:none;color:var(--txt3);cursor:pointer;font-size:17px;line-height:1;padding:2px;transition:color .15s}
.mx:hover{color:var(--red)}

/* ─── ARCHIVE ─── */
.arch-nav{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.arch-mon{font-family:var(--serif);font-size:16px;font-weight:700;color:var(--txt)}
.arch-arr{padding:5px 12px;border-radius:10px;font-size:11px;font-weight:600;font-family:var(--sans);background:var(--bg2);border:1px solid var(--bdr);color:var(--txt2);cursor:pointer;transition:all .15s}
.arch-arr:hover{border-color:var(--acc);color:var(--acc)}
.ach-hdr{display:grid;grid-template-columns:repeat(7,1fr);gap:3px;margin-bottom:3px}
.ach-hdr div{text-align:center;font-size:8px;color:var(--txt3);font-weight:700;text-transform:uppercase;letter-spacing:.06em}
.ach-g{display:grid;grid-template-columns:repeat(7,1fr);gap:3px;margin-bottom:14px}
.acd{aspect-ratio:1;background:var(--bg2);border:1px solid var(--bdr);border-radius:8px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:10px;cursor:pointer;color:var(--txt3);transition:all .18s}
.acd:hover{border-color:var(--acc);color:var(--acc)}
.acd.today{border-color:var(--acc2);color:var(--acc2)}
.acd.has{background:rgba(61,158,255,.1);color:var(--txt)}
.acd .d3{width:3px;height:3px;border-radius:50%;background:var(--acc2);margin-top:2px}
.sec-lbl{font-size:9px;font-weight:800;color:var(--txt3);text-transform:uppercase;letter-spacing:.15em;margin-bottom:9px}
.str-item{padding:11px 13px;background:var(--bg2);border:1px solid var(--bdr);border-radius:12px;margin-bottom:6px;cursor:pointer;transition:border-color .18s}
.str-item:hover{border-color:var(--acc)}
.str-meta{font-size:8px;color:var(--txt3);text-transform:uppercase;letter-spacing:.09em;margin-bottom:4px}
.str-title{font-family:var(--serif);font-size:13px;color:var(--txt);line-height:1.35}

/* ─── SETTINGS ─── */
.sg{margin-bottom:14px}
.sl{font-size:9px;font-weight:800;color:var(--txt3);text-transform:uppercase;letter-spacing:.15em;margin-bottom:6px}
.si{width:100%;background:var(--bg2);border:1px solid var(--bdr2);border-radius:11px;padding:10px 13px;font-size:12px;font-family:var(--sans);color:var(--txt);outline:none;margin-bottom:5px;transition:border-color .2s}
.si:focus{border-color:var(--acc)}
.si option{background:var(--bg1)}
.sbtn{padding:8px 15px;border-radius:11px;font-size:10px;font-weight:700;font-family:var(--sans);background:var(--bg2);border:1px solid var(--bdr);color:var(--txt2);cursor:pointer;transition:all .18s;letter-spacing:.05em;text-transform:uppercase}
.sbtn:hover{border-color:var(--acc);color:var(--acc)}
.sbtn.danger{border-color:rgba(255,51,85,.28);color:var(--red)}
.sbtn.danger:hover{background:rgba(255,51,85,.07)}

/* ─── INTERESTS ─── */
.int-grid{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px}
.int-item{display:flex;align-items:center;gap:7px;padding:8px 13px;border-radius:12px;background:var(--bg2);border:1px solid var(--bdr);cursor:pointer;transition:all .2s;font-size:11px;font-weight:600;color:var(--txt2);user-select:none}
.int-item.on{background:rgba(61,158,255,.1);border-color:var(--acc);color:var(--acc)}
.int-item.locked{opacity:.5;cursor:not-allowed}
